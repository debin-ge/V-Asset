# V-Asset 后端服务环境变量配置模板
# 复制此文件为 .env 并修改配置

# ==================== 数据库配置 ====================
DB_HOST=postgres
DB_PORT=5432
DB_USER=vasset
DB_PASSWORD=password
DB_NAME=vasset

# ==================== Redis 配置 ====================
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=password

# ==================== 服务地址 ====================
AUTH_SERVICE_HOST=auth-service
AUTH_SERVICE_PORT=9001
ASSET_SERVICE_HOST=asset-service
ASSET_SERVICE_PORT=9004
PROXY_SERVICE_HOST=proxy-service
PROXY_SERVICE_PORT=9010
API_GATEWAY_HOST=api-gateway
API_GATEWAY_PORT=8080

# ==================== JWT 配置 ====================
JWT_SECRET=your-secret-key-change-in-production

# ==================== 前端配置 ====================
NEXT_PUBLIC_API_BASE_URL=http://localhost:8080


# ==================== 代理配置 ====================
YTDLP_API_BASE_URL=http://localhost