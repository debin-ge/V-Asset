DB_USER=vasset
DB_PASSWORD=password
DB_NAME=vasset
DB_HOST=postgres
DB_PORT=5432

REDIS_ADDR=redis:6379
REDIS_PASSWORD=

RABBITMQ_URL=amqp://guest:guest@rabbitmq:5672/

AUTH_SERVICE_ADDR=auth-service:9001
MEDIA_SERVICE_ADDR=media-service:9002
ASSET_SERVICE_ADDR=asset-service:9004
ADMIN_SERVICE_ADDR=admin-service:9005

JWT_SECRET=your-secret-key-change-in-production

# Frontend public origin
# Local dev: http://localhost:8080
# Cloudflare / production: leave blank to follow window.location.origin,
NEXT_PUBLIC_API_BASE_URL=
NEXT_PUBLIC_WS_URL=

# Frontend version detection
# APP_VERSION carries the deployed frontend version identifier.
# Recommended values: Git SHA or image tag.
# If APP_VERSION is empty, the frontend falls back to BUILD_TIMESTAMP.
APP_VERSION=
BUILD_TIMESTAMP=

# Admin frontend server-side proxy target (container-internal)
API_GATEWAY_INTERNAL_URL=http://api-gateway:8080
NEXT_PUBLIC_PARSE_TIMEOUT_MS=300000

CORS_ALLOWED_ORIGINS=*
CORS_ALLOWED_HEADERS=Content-Type,Authorization
SESSION_SECURE=false
SESSION_SAME_SITE=Lax
SESSION_COOKIE_DOMAIN=
ADMIN_SESSION_COOKIE_NAME=vasset_admin_session
ADMIN_SESSION_SECURE=false
ADMIN_SESSION_SAME_SITE=Lax
ADMIN_SESSION_COOKIE_DOMAIN=

PROXY_API_ENDPOINT=
PROXY_API_KEY=
