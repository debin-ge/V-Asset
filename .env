# V-Asset 后端服务环境变量配置模板
# 复制此文件为 .env 并修改配置

# ==================== 数据库配置 ====================
DB_HOST=postgres
DB_PORT=5432
DB_USER=vasset
DB_PASSWORD=Vasset_Passw0rd
DB_NAME=vasset

# ==================== Redis 配置 ====================
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=password

# ==================== 服务地址 ====================
AUTH_SERVICE_ADDR=auth-service:9001
PARSER_SERVICE_ADDR=parser-service:9002
DOWNLOADER_SERVICE_ADDR=downloader-service:9003
ASSET_SERVICE_ADDR=asset-service:9004

# ==================== JWT 配置 ====================
JWT_SECRET=your-secret-key-change-in-production

# ==================== 代理配置 (可选) ====================
# PROXY_API_KEY=your-proxy-api-key

# ==================== 前端配置 ====================
NEXT_PUBLIC_API_BASE_URL=http://localhost:8080
